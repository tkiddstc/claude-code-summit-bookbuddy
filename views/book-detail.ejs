<%- include('header') %>

<% function stars(rating) {
  const full = Math.round(rating);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
} %>

<div class="detail-layout">

  <!-- Left: book info -->
  <aside class="book-info-panel">
    <div class="book-info-card">
      <h1><%= book.title %></h1>
      <p class="author">by <%= book.author %></p>
      <% if (book.isbn) { %>
        <p class="isbn">ISBN: <%= book.isbn %></p>
      <% } %>
      <% if (rating_info.avg_rating) { %>
        <div class="avg-rating">
          <span class="stars"><%= stars(rating_info.avg_rating) %></span>
          <span class="rating-number"><%= rating_info.avg_rating.toFixed(1) %></span>
          <span class="review-count">(<%= rating_info.review_count %> review<%= rating_info.review_count !== 1 ? 's' : '' %>)</span>
        </div>
      <% } else { %>
        <p class="empty">No ratings yet</p>
      <% } %>
      <% if (book.description) { %>
        <p class="book-description"><%= book.description %></p>
      <% } %>
      <div class="book-actions">
        <a href="/books/<%= book.id %>/edit" class="btn btn-secondary">Edit</a>
        <form method="POST" action="/books/<%= book.id %>/delete" style="display:inline">
          <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this book?')">Delete</button>
        </form>
      </div>
    </div>
  </aside>

  <!-- Right: reviews -->
  <section class="reviews-panel">
    <h2>Reviews</h2>

    <% if (reviews.length === 0) { %>
      <p class="empty">No reviews yet. Be the first!</p>
    <% } else { %>
      <div class="reviews">
        <% reviews.forEach(review => { %>
          <div class="review-card">
            <div class="review-avatar"><%= review.reviewer_name.charAt(0).toUpperCase() %></div>
            <div class="review-body">
              <div class="review-header">
                <strong class="reviewer-name"><%= review.reviewer_name %></strong>
                <span class="review-stars"><%= stars(review.rating) %></span>
              </div>
              <% if (review.review_text) { %>
                <p class="review-text"><%= review.review_text %></p>
              <% } %>
              <form method="POST" action="/reviews/<%= review.id %>/delete" style="margin-top:0.5rem">
                <button type="submit" class="btn-small btn-danger">Remove</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div class="add-review-card">
      <h3>Add a Review</h3>
      <form method="POST" action="/reviews">
        <input type="hidden" name="book_id" value="<%= book.id %>">
        <div class="form-group">
          <label for="reviewer_name">Your Name</label>
          <input type="text" id="reviewer_name" name="reviewer_name" required>
        </div>
        <div class="form-group">
          <label for="rating">Rating</label>
          <select id="rating" name="rating" required>
            <option value="">Select...</option>
            <option value="5">★★★★★ — Excellent</option>
            <option value="4">★★★★☆ — Good</option>
            <option value="3">★★★☆☆ — OK</option>
            <option value="2">★★☆☆☆ — Poor</option>
            <option value="1">★☆☆☆☆ — Terrible</option>
          </select>
        </div>
        <div class="form-group">
          <label for="review_text">Review (optional)</label>
          <textarea id="review_text" name="review_text" rows="3"></textarea>
        </div>
        <button type="submit" class="btn">Submit Review</button>
      </form>
    </div>
  </section>

</div>

<%- include('footer') %>
